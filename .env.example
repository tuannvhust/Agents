# ============================================================
# Application
# ============================================================
APP_HOST=0.0.0.0
APP_PORT=8080          # host port → container 8000
APP_DEBUG=false
APP_LOG_LEVEL=INFO
API_KEY=
# ============================================================
# Openrouter (LLM Foundation Model)
# ============================================================
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_DEFAULT_MODEL=qwen/qwen3-30b-a3b-thinking-2507
OPENROUTER_MAX_TOKENS=8192
OPENROUTER_TEMPERATURE=0.0

# Local model (optional — set if using a local endpoint instead of Openrouter)
LOCAL_MODEL_BASE_URL=http://localhost:11434/v1
LOCAL_MODEL_API_KEY=ollama
LOCAL_MODEL_NAME=

# ============================================================
# Langfuse (Observability + Prompt Management)
# ============================================================
LANGFUSE_HOST=http://localhost
LANGFUSE_PORT=3001         # host port (docker-compose maps 3001→3000 inside)
LANGFUSE_HOST_PORT=3001    # used by docker-compose for host port binding
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# ============================================================
# MinIO (Object Storage)
# ============================================================
MINIO_ENDPOINT=localhost:9100   # host port (docker-compose maps 9100→9000 inside)
MINIO_HOST_PORT=9100
MINIO_CONSOLE_PORT=9101
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=agent-files
MINIO_SECURE=false
# Prefix file tool paths with runs/{agent_name}/{run_id}/ (session_id = run_id). Set false for legacy flat keys.
MINIO_SCOPE_PATHS_TO_RUN=true

# ============================================================
# ElasticSearch (Logging & Monitoring)
# ============================================================
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=agent-system-logs
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# ============================================================
# Agent PostgreSQL (used by agents via MCP postgres server)
# NOTE: In docker-compose the MCP_SERVERS env is overridden to
#       use the internal hostname "agent-postgres:5432".
#       These vars are used for local development (localhost).
# ============================================================
AGENT_POSTGRES_USER=agent
AGENT_POSTGRES_PASSWORD=agent
AGENT_POSTGRES_DB=agentdb
AGENT_POSTGRES_PORT=5433

# ============================================================
# Chainlit Chat UI
# Port on which the Chainlit app listens inside Docker (host → container 8501)
# ============================================================
CHAT_PORT=8501

# ============================================================
# Repository cache (Redis) — Postgres remains source of truth
# CACHE_ENABLED=false → no Redis connection; API uses Postgres only (default).
# CACHE_ENABLED=true + CACHE_TYPE=redis → startup connects to CACHE_REDIS_URL;
#   repeated reads (agent memory, run rows, tool_calls) use Redis with TTL.
# Docker Compose overrides CACHE_REDIS_URL to redis://agent-redis:6379/0 and maps host port 6380→6379.
# Start the agent-redis service (or any Redis) before enabling CACHE_ENABLED=true.
# ============================================================
CACHE_ENABLED=false
CACHE_TYPE=redis
CACHE_REDIS_URL=redis://localhost:6380/0
CACHE_DEFAULT_TTL_SECONDS=300
CACHE_MEMORY_TTL_SECONDS=600
CACHE_CONVERSATION_TTL_SECONDS=120
CACHE_TOOL_MESSAGES_TTL_SECONDS=120

# ============================================================
# OCR gateway (optional — multipart job API)
# POST OCR_URL with doc_type + file; poll GET OCR_URL/{job_ckey}
# Tools: ocr_document (path inside API container), ocr_minio_document (MinIO path like read_file)
# Docker: put PDFs in ./ocr_input on the host → use /ocr_input/file.pdf in ocr_document
#
# Networking: API in Docker cannot reach OCR on the host via http://localhost:... (localhost =
# the container itself). Use host.docker.internal (Docker Desktop Mac/Windows), e.g.:
#   OCR_URL=http://host.docker.internal:9999/api/v1/job
# Linux: add to the app service in docker-compose:
#   extra_hosts:
#     - "host.docker.internal:host-gateway"
# Or run the OCR service on the same Docker network and use its service name as host.
# ============================================================
OCR_URL=
OCR_API_KEY=
# Defaults when the agent omits ocr_document poll parameters
OCR_POLL_INTERVAL=5
OCR_MAX_WAIT_SECONDS=600

# ============================================================
# Skills
# ============================================================
# Mode for loading agent skills (SKILLS.md files):
#   local    — always read from ./skills directory
#   langfuse — always fetch from Langfuse prompts (requires keys above)
#   hybrid   — prefer Langfuse, silently fall back to local on any failure (DEFAULT)
SKILLS_SOURCE=hybrid
SKILLS_LOCAL_DIR=./skills
# How long (seconds) a Langfuse-fetched skill stays in cache before re-fetching
LANGFUSE_EXPIRY_TIME=100

# ============================================================
# Guardrails (SafetyPlugin rules under guardrails/*.md)
# ============================================================
# Same modes as skills: local | langfuse | hybrid (default)
GUARDRAILS_SOURCE=hybrid
GUARDRAILS_LOCAL_DIR=./guardrails
GUARDRAILS_EXPIRY_TIME=100

# ============================================================
# MCP Servers (JSON array of MCP server configurations)
# Each entry: {"name": "...", "command": "...", "args": [...], "env": {...}}
#
# LOCAL DEVELOPMENT: uses localhost (docker-compose overrides this with the
#                    internal hostname "agent-postgres:5432").
#
# Add more servers to the array to enable additional MCP tools:
#   filesystem:   npx -y @modelcontextprotocol/server-filesystem /tmp
#   brave-search: npx -y @modelcontextprotocol/server-brave-search  (needs BRAVE_API_KEY)
#   github:       npx -y @modelcontextprotocol/server-github         (needs GITHUB_TOKEN)
#   fetch:        npx -y @modelcontextprotocol/server-fetch
# ============================================================
MCP_SERVERS=[{"name":"postgres","command":"npx","args":["--yes","@modelcontextprotocol/server-postgres","postgresql://agent:agent@localhost:5432/agentdb"]}]
