# ============================================================
# Application
# ============================================================
APP_HOST=0.0.0.0
APP_PORT=8080          # host port → container 8000
APP_DEBUG=false
APP_LOG_LEVEL=INFO
API_KEY=               # leave blank to disable API key auth (local dev)

# ============================================================
# Openrouter (LLM Foundation Model)
# ============================================================
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_DEFAULT_MODEL=qwen/qwen3-30b-a3b-thinking-2507
OPENROUTER_MAX_TOKENS=8192
OPENROUTER_TEMPERATURE=0.0

# Local model (optional — set if using a local endpoint instead of Openrouter)
LOCAL_MODEL_BASE_URL=http://localhost:11434/v1
LOCAL_MODEL_API_KEY=ollama
LOCAL_MODEL_NAME=

# ============================================================
# Langfuse (Observability + Prompt Management)
# ============================================================
LANGFUSE_HOST=http://localhost
LANGFUSE_PORT=3001         # host port (docker-compose maps 3001→3000 inside)
LANGFUSE_HOST_PORT=3001    # used by docker-compose for host port binding
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# ============================================================
# MinIO (Object Storage)
# ============================================================
MINIO_ENDPOINT=localhost:9100   # host port (docker-compose maps 9100→9000 inside)
MINIO_HOST_PORT=9100
MINIO_CONSOLE_PORT=9101
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=agent-files
MINIO_SECURE=false

# ============================================================
# ElasticSearch (Logging & Monitoring)
# ============================================================
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=agent-system-logs
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# ============================================================
# Agent PostgreSQL (used by agents via MCP postgres server)
# NOTE: In docker-compose the MCP_SERVERS env is overridden to
#       use the internal hostname "agent-postgres:5432".
#       These vars are used for local development (localhost).
# ============================================================
AGENT_POSTGRES_USER=agent
AGENT_POSTGRES_PASSWORD=agent
AGENT_POSTGRES_DB=agentdb
AGENT_POSTGRES_PORT=5433

# ============================================================
# Skills
# ============================================================
# Mode for loading agent skills (SKILLS.md files):
#   local    — always read from ./skills directory
#   langfuse — always fetch from Langfuse prompts (requires keys above)
#   hybrid   — prefer Langfuse, silently fall back to local on any failure (DEFAULT)
SKILLS_SOURCE=hybrid
SKILLS_LOCAL_DIR=./skills
# How long (seconds) a Langfuse-fetched skill stays in cache before re-fetching
LANGFUSE_EXPIRY_TIME=100

# ============================================================
# MCP Servers (JSON array of MCP server configurations)
# Each entry: {"name": "...", "command": "...", "args": [...], "env": {...}}
#
# LOCAL DEVELOPMENT: uses localhost (docker-compose overrides this with the
#                    internal hostname "agent-postgres:5432").
#
# Add more servers to the array to enable additional MCP tools:
#   filesystem:   npx -y @modelcontextprotocol/server-filesystem /tmp
#   brave-search: npx -y @modelcontextprotocol/server-brave-search  (needs BRAVE_API_KEY)
#   github:       npx -y @modelcontextprotocol/server-github         (needs GITHUB_TOKEN)
#   fetch:        npx -y @modelcontextprotocol/server-fetch
# ============================================================
MCP_SERVERS=[{"name":"postgres","command":"npx","args":["--yes","@modelcontextprotocol/server-postgres","postgresql://agent:agent@localhost:5432/agentdb"]}]
